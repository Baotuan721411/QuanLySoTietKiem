<Window x:Class="QuanLiSoTietKiem.QuanLy.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:QuanLiSoTietKiem.QuanLy.ViewModels"
        Title="Quản lý sổ tiết kiệm" Height="550" Width="800" 
        WindowStartupLocation="CenterScreen" Background="#FFFDE7">

    <Window.DataContext>
        <vm:MainViewModels/>
    </Window.DataContext>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Quản lý sổ tiết kiệm" FontSize="24" FontWeight="Bold" 
                   Foreground="#333" Margin="0,0,0,25"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,15,15">
                <TextBlock Text="Mã sổ:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding MaSo}" IsEnabled="False" Height="35" VerticalContentAlignment="Center" Background="#F0F0F0"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,15,15">
                <TextBlock Text="Khách hàng:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding TenKH, UpdateSourceTrigger=PropertyChanged}" Height="35" VerticalContentAlignment="Center"/>
            </StackPanel>
            
            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,15,15">
                <TextBlock Text="Ngày sinh:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <DatePicker SelectedDate="{Binding NgaySinh}" Height="35"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,15,15">
                <TextBlock Text="Số tiền gửi:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding SoTienStr, UpdateSourceTrigger=PropertyChanged}" Height="35" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="1" Margin="15,0,0,15">
                <TextBlock Text="Loại tiết kiệm:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding ListLoaiTK}" 
                          SelectedValuePath="MaLoaiTietKiem" 
                          DisplayMemberPath="TenLoaiTietKiem" 
                          SelectedValue="{Binding SelectedLoaiId}" 
                          Height="35" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="1" Margin="15,0,0,15">
                <TextBlock Text="CCCD:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding CCCD, UpdateSourceTrigger=PropertyChanged}" Height="35" VerticalContentAlignment="Center"/>
            </StackPanel>
            

            <StackPanel Grid.Row="2" Grid.Column="1" Margin="15,0,0,15">
                <TextBlock Text="Ngày mở sổ:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <DatePicker SelectedDate="{Binding NgayMoSo}" Height="35" IsEnabled="True"/>
            </StackPanel>



            <StackPanel Grid.Row="3" Grid.Column="1" Margin="15,0,0,15">
                <TextBlock Text="Địa chỉ:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox Text="{Binding DiaChi, UpdateSourceTrigger=PropertyChanged}" Height="35" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <WrapPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,20,0,0">
            <WrapPanel.Resources>
                <Style TargetType="Button">
                    <Setter Property="Width" Value="110"/>
                    <Setter Property="Height" Value="38"/>
                    <Setter Property="Margin" Value="5"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Style.Resources>
                </Style>
            </WrapPanel.Resources>

            <Button Content="Tiếp nhận sổ" Command="{Binding TiepNhanCommand}" Background="#4DA6FF"/>
            <Button Content="Tạo sổ mới" Background="#4DA6FF"/>
            <Button Content="Tìm sổ" Background="#4DA6FF"/>
            <Button Content="Xóa sổ" Background="#4DA6FF"/>
            <Button Content="Cập nhật sổ" Background="#4DA6FF"/>
            <Button Content="Thoát" Command="{Binding ThoatCommand}" Background="#FF4D4D"/>
        </WrapPanel>
    </Grid>
</Window>
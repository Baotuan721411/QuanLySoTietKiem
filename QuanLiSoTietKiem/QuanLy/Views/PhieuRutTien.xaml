<UserControl x:Class="QuanLiSoTietKiem.QuanLy.Views.PhieuRutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:QuanLiSoTietKiem.QuanLy.ViewModels"
        Background="#F5F2DF">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Background="#F5F0A0" Grid.Row="0"  Padding="16,10">
            <TextBlock Text="Lập phiếu rút tiền" FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="30,0" Foreground="Black"/>
        </Border>

        <Grid Grid.Row="1" Margin="30,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Mã phiếu rút:" FontWeight="SemiBold" Margin="0,5"/>
                <TextBox Text="{Binding MaPhieuRutDisplay}" IsReadOnly="True" Background="#E0E0E0" Height="32" VerticalContentAlignment="Center"/>

                <TextBlock Text="Ngày rút:" FontWeight="SemiBold" Margin="0,15,0,5"/>
                <DatePicker SelectedDate="{Binding NgayRut}" Height="32"/>

                <TextBlock Text="Số tiền rút:" FontWeight="SemiBold" Margin="0,15,0,5"/>
                <TextBox Text="{Binding SoTienRutStr, UpdateSourceTrigger=PropertyChanged}" Height="32" VerticalContentAlignment="Center" BorderBrush="#2196F3"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Mã sổ:" FontWeight="SemiBold" Margin="0,5"/>
                <ComboBox ItemsSource="{Binding ListMaSo}"
                          Text="{Binding MaSo, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="False" Height="32" VerticalContentAlignment="Center"/>

                <TextBlock Text="Thời gian mở sổ (Ngày):" FontWeight="SemiBold" Margin="0,15,0,5"/>
                <TextBox Text="{Binding ThoiGianMoSo}" IsReadOnly="True" Background="#E0E0E0" Height="32" VerticalContentAlignment="Center"/>

                <TextBlock Text="Số tiền hiện có:" FontWeight="SemiBold" Margin="0,15,0,5"/>
                <TextBox Text="{Binding SoTienHienTaiStr}" IsReadOnly="True" Background="#E0E0E0" Height="32" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="4">
                <TextBlock Text="Khách hàng:" FontWeight="SemiBold" Margin="0,5"/>
                <TextBox Text="{Binding TenKH}" Height="32" VerticalContentAlignment="Center"/>

                <TextBlock Text="Qui định Thời gian rút tiền (Ngày):" FontWeight="SemiBold" Margin="0,15,0,5"/>
                <TextBox Text="{Binding ThoiGianRutTien}" IsReadOnly="True" Background="#E0E0E0" Height="32" VerticalContentAlignment="Center"/>

                <TextBlock Text="Qui định Rút tiền:" FontWeight="SemiBold" Margin="0,15,0,5"/>
                <TextBox Text="{Binding QuiDinhRutTien}" IsReadOnly="True" Background="#E0E0E0" Height="32" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Margin="30,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Button Content="Lập phiếu rút tiền" Command="{Binding LapPhieuCommand}" Width="130" Height="38" Background="#2196F3" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                <Button Content="Tra cứu sổ"    Command="{Binding TraCuuCommand}"   Width="110" Height="38" Margin="15,0" Background="#2196F3" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="QuanLiSoTietKiem.QuanLy.Views.TraCuuSoTietKiem"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:QuanLiSoTietKiem.QuanLy.ViewModels"
        Background="#F5F2DF">

    <UserControl.Resources>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#222222"/>
        </Style>

        <Style x:Key="SubLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Foreground" Value="#FF0000"/>
        </Style>

        <Style x:Key="RedLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Foreground" Value="#FF0000"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="BorderBrush" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="DarkComboStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Background" Value="#666666"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#444444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="26"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F5F5F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,0"/>
        </Style>

        <Style x:Key="DatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Border Grid.Row="0" Background="#F5F0A0" Padding="16,10">
            <TextBlock Text="Tra cứu sổ tiết kiệm"
                       FontSize="18" FontWeight="Bold"
                       VerticalAlignment="Center" Foreground="#222222"/>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1" Margin="16,12,16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- FILTER PANEL -->
            <Border Grid.Row="0" Background="White" BorderBrush="#DDDDDD"
                    BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,10">
                <StackPanel>

                    <!-- ROW 1 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Mã số" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding FilterMaSo, UpdateSourceTrigger=PropertyChanged}" Tag="&lt; Có chứa &gt;"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Khách hàng" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding FilterKhachHang, UpdateSourceTrigger=PropertyChanged}" Tag="&lt; Có chứa &gt;"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Ngày sinh" Style="{StaticResource LabelStyle}"/>
                            <DatePicker SelectedDate="{Binding FilterNgaySinh}" Style="{StaticResource DatePickerStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="6">
                            <TextBlock Text="CCCD" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding FilterCCCD, UpdateSourceTrigger=PropertyChanged}" Tag="&lt; Có chứa &gt;"/>
                        </StackPanel>

                        <StackPanel Grid.Column="8">
                            <TextBlock Text="Địa chỉ" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding FilterDiaChi, UpdateSourceTrigger=PropertyChanged}" Tag="&lt; Có chứa &gt;"/>
                        </StackPanel>

                        <StackPanel Grid.Column="10">
                            <TextBlock Text="Tên loại tiết kiệm" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding ListLoaiTietKiem}" SelectedItem="{Binding FilterLoaiTietKiem}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="12">
                            <TextBlock Text="Trạng thái" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding ListTrangThai}" SelectedItem="{Binding FilterTrangThai}"/>
                        </StackPanel>
                    </Grid>

                    <!-- ROW 2+3 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold">
                                    <Run Text="Ngày mở sổ "/>
                                    <Run Text="từ" Foreground="#FF0000"/>
                                </TextBlock>
                                <DatePicker Grid.Column="2" SelectedDate="{Binding FilterNgayMoSoTu}" Style="{StaticResource DatePickerStyle}"/>
                                <TextBlock Grid.Column="3" Text="đến" Style="{StaticResource SubLabelStyle}"/>
                                <DatePicker Grid.Column="4" SelectedDate="{Binding FilterNgayMoSoDen}" Style="{StaticResource DatePickerStyle}"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold">
                                    <Run Text="Số tiền "/>
                                    <Run Text="từ" Foreground="#FF0000"/>
                                </TextBlock>
                                <TextBox Grid.Column="2" Text="{Binding FilterSoTienTu, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="3" Text="đến" Style="{StaticResource RedLabelStyle}"/>
                                <TextBox Grid.Column="4" Text="{Binding FilterSoTienDen, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold">
                                    <Run Text="Ngày cập nhật gần nhất "/>
                                    <Run Text="từ" Foreground="#FF0000"/>
                                </TextBlock>
                                <DatePicker Grid.Column="2" SelectedDate="{Binding FilterNgayCapNhatTu}" Style="{StaticResource DatePickerStyle}"/>
                                <TextBlock Grid.Column="3" Text="đến" Style="{StaticResource SubLabelStyle}"/>
                                <DatePicker Grid.Column="4" SelectedDate="{Binding FilterNgayCapNhatDen}" Style="{StaticResource DatePickerStyle}"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold">
                                    <Run Text="Số dư tối thiểu "/>
                                    <Run Text="từ" Foreground="#FF0000"/>
                                </TextBlock>
                                <TextBox Grid.Column="2" Text="{Binding FilterSoDuToiThieuTu, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="3" Text="đến" Style="{StaticResource RedLabelStyle}"/>
                                <TextBox Grid.Column="4" Text="{Binding FilterSoDuToiThieuDen, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- ROW 4 -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Quy định Thời gian rút tiền" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding ListQuyDinhThoiGian}" SelectedItem="{Binding FilterQuyDinhThoiGian}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Quy định Rút tiền" Style="{StaticResource LabelStyle}"/>
                            <ComboBox ItemsSource="{Binding ListQuyDinhRutTien}" SelectedItem="{Binding FilterQuyDinhRutTien}"/>
                        </StackPanel>

                        <Grid Grid.Column="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold">
                                <Run Text="Lãi suất "/>
                                <Run Text="từ" Foreground="#FF0000"/>
                            </TextBlock>
                            <TextBox Grid.Column="2" Text="{Binding FilterLaiSuatTu, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="3" Text="đến" Style="{StaticResource RedLabelStyle}"/>
                            <TextBox Grid.Column="4" Text="{Binding FilterLaiSuatDen, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </Grid>

                    <!-- ROW 5+6+7 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="Mã phiếu gởi" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding FilterMaPhieuGoi, UpdateSourceTrigger=PropertyChanged}" Tag="&lt; Có chứa &gt;"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold">
                                    <Run Text="Ngày gởi "/>
                                    <Run Text="từ" Foreground="#FF0000"/>
                                </TextBlock>
                                <DatePicker Grid.Column="2" SelectedDate="{Binding FilterNgayGoiTu}" Style="{StaticResource DatePickerStyle}"/>
                                <TextBlock Grid.Column="3" Text="đến" Style="{StaticResource SubLabelStyle}"/>
                                <DatePicker Grid.Column="4" SelectedDate="{Binding FilterNgayGoiDen}" Style="{StaticResource DatePickerStyle}"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold">
                                    <Run Text="Số tiền gởi "/>
                                    <Run Text="từ" Foreground="#FF0000"/>
                                </TextBlock>
                                <TextBox Grid.Column="2" Text="{Binding FilterSoTienGoiTu, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="3" Text="đến" Style="{StaticResource RedLabelStyle}"/>
                                <TextBox Grid.Column="4" Text="{Binding FilterSoTienGoiDen, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Text="Mã phiếu rút" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding FilterMaPhieuRut, UpdateSourceTrigger=PropertyChanged}" Tag="&lt; Có chứa &gt;"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold">
                                    <Run Text="Ngày rút "/>
                                    <Run Text="từ" Foreground="#FF0000"/>
                                </TextBlock>
                                <DatePicker Grid.Column="2" SelectedDate="{Binding FilterNgayRutTu}" Style="{StaticResource DatePickerStyle}"/>
                                <TextBlock Grid.Column="3" Text="đến" Style="{StaticResource SubLabelStyle}"/>
                                <DatePicker Grid.Column="4" SelectedDate="{Binding FilterNgayRutDen}" Style="{StaticResource DatePickerStyle}"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold">
                                    <Run Text="Số tiền rút "/>
                                    <Run Text="từ" Foreground="#FF0000"/>
                                </TextBlock>
                                <TextBox Grid.Column="2" Text="{Binding FilterSoTienRutTu, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Grid.Column="3" Text="đến" Style="{StaticResource RedLabelStyle}"/>
                                <TextBox Grid.Column="4" Text="{Binding FilterSoTienRutDen, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- DATA GRID -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding ListSoResult}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Background="White" RowHeight="26" FontSize="12"
                      GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E0E0E0"
                      AlternationCount="2" BorderBrush="#CCCCCC" BorderThickness="1"
                      CanUserResizeColumns="True" CanUserSortColumns="True"
                      SelectionMode="Single" SelectionUnit="FullRow">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="STT"                     Binding="{Binding STT}"                                       Width="45"/>
                    <DataGridTextColumn Header="MÃ SỐ"                   Binding="{Binding MaSo}"                                       Width="80" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="KHÁCH HÀNG"              Binding="{Binding TenKH}"                                      Width="*"/>
                    <DataGridTextColumn Header="NGÀY SINH"               Binding="{Binding NgaySinh,    StringFormat={}{0:dd/MM/yyyy}}" Width="90"/>
                    <DataGridTextColumn Header="CCCD"                    Binding="{Binding CCCD}"                                       Width="110"/>
                    <DataGridTextColumn Header="ĐỊA CHỈ"                Binding="{Binding DiaChi}"                                     Width="2*"/>
                    <DataGridTextColumn Header="NGÀY MỞ SỔ"             Binding="{Binding NgayMoSo,    StringFormat={}{0:dd/MM/yyyy}}" Width="100"/>
                    <DataGridTextColumn Header="NGÀY CẬP NHẬT GẦN NHẤT" Binding="{Binding NgayCapNhat, StringFormat={}{0:dd/MM/yyyy}}" Width="175"/>
                    <DataGridTextColumn Header="SỐ TIỀN"                Binding="{Binding SoTien,      StringFormat={}{0:N0}}"         Width="110"/>
                    <DataGridTextColumn Header="SỐ DƯ TỐI THIỂU"       Binding="{Binding SoDuToiThieu,StringFormat={}{0:N0}}"         Width="130"/>
                    <DataGridTextColumn Header="TÊN LOẠI TIẾT KIỆM"     Binding="{Binding TenLoaiTietKiem}"                            Width="145"/>
                    <DataGridTextColumn Header="TRẠNG THÁI"              Binding="{Binding TrangThai}"                                  Width="100"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- BUTTON BAR -->
            <Border Grid.Row="2" Background="#F0EDD8" BorderBrush="#DDDDDD"
                    BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Tra cứu sổ"
                            Command="{Binding TraCuuCommand}"
                            Width="130" Height="38"
                            Background="#2196F3" Foreground="White"
                            FontWeight="Bold" FontSize="13"
                            BorderThickness="0" Cursor="Hand"/>
                    <Button Content="Làm mới"
                            Command="{Binding LamMoiCommand}"
                            Width="130" Height="38" Margin="10,0,0,0"
                            Background="#2196F3" Foreground="White"
                            FontWeight="Bold" FontSize="13"
                            BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</UserControl>

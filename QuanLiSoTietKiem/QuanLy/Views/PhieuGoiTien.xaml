<UserControl x:Class="QuanLiSoTietKiem.QuanLy.Views.PhieuGoiWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:QuanLiSoTietKiem.QuanLy.ViewModels"
        Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Background="#FFB300" Grid.Row="0">
            <TextBlock Text="Lập phiếu gởi tiền" FontSize="20" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="20,0" Foreground="Black"/>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Mã phiếu gởi:" Margin="0,5"/>
                <TextBox Text="{Binding MaPhieuGoiDisplay}" IsReadOnly="True" Background="#E0E0E0" Height="30" VerticalContentAlignment="Center"/>

                <TextBlock Text="Mã sổ:" Margin="0,15,0,5"/>
                <ComboBox ItemsSource="{Binding ListMaSo}"
                          Text="{Binding MaSo, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="True" Height="30" VerticalContentAlignment="Center"/>

                <TextBlock Text="Loại tiết kiệm:" Margin="0,15,0,5"/>
                <TextBox Text="{Binding LoaiTietKiemHienTai}" IsReadOnly="True" Background="#E0E0E0" Height="30" VerticalContentAlignment="Center"/>

                <TextBlock Text="Số tiền gởi:" Margin="0,15,0,5"/>
                <TextBox Text="{Binding SoTienGoiStr, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Ngày gởi:" Margin="0,5"/>
                <DatePicker SelectedDate="{Binding NgayGoi}" Height="30" IsEnabled="True"/>

                <TextBlock Text="Khách hàng:" Margin="0,15,0,5"/>
                <TextBox Text="{Binding TenKH}" Height="30" VerticalContentAlignment="Center"/>

                <TextBlock Text="Quy định Loại tiết kiệm khi gởi:" Margin="0,15,0,5"/>
                <TextBox Text="{Binding QuyDinhLoaiTK}" IsReadOnly="True" Background="#E0E0E0" Height="30" VerticalContentAlignment="Center"/>

                <TextBlock Text="Quy định Số tiền gởi thêm tối thiểu:" Margin="0,15,0,5"/>
                <TextBox Text="{Binding QuyDinhSoTien}" IsReadOnly="True" Background="#E0E0E0" Height="30" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,0">
            <Button Content="Lập phiếu gởi" Command="{Binding LapPhieuCommand}" Width="120" Height="36" Background="#2196F3" Foreground="White" BorderThickness="0"/>
            <Button Content="Tra cứu sổ"    Command="{Binding TraCuuCommand}"   Width="100" Height="35" Margin="10,0" Background="#2196F3" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</UserControl>

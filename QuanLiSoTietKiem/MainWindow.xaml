<Window x:Class="QuanLiSoTietKiem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý sổ tiết kiệm" Height="520" Width="750" 
        WindowStartupLocation="CenterScreen" Background="#FFFDE7">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Quản lý sổ tiết kiệm" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" Foreground="#333"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,20,15">
                <TextBlock Text="Mã sổ:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtMaSo" Height="32" VerticalContentAlignment="Center" IsEnabled="False" Text="&lt;Giá trị phát sinh&gt;" Background="#F5F5F5"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,20,15">
                <TextBlock Text="Khách hàng:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtTenKH" Height="32" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,20,15">
                <TextBlock Text="Ngày sinh:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <DatePicker x:Name="dpNgaySinh" Height="32"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,20,15">
                <TextBlock Text="Số tiền gửi:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtSoTien" Height="32" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,15">
                <TextBlock Text="Loại tiết kiệm:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <ComboBox x:Name="cbLoaiTK" Height="32" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,15">
                <TextBlock Text="CCCD:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtCCCD" Height="32" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,15">
                <TextBlock Text="Ngày mở sổ:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <DatePicker x:Name="dpNgayMo" Height="32"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,15">
                <TextBlock Text="Địa chỉ:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtDiaChi" Height="32" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <StackPanel.Resources>
                <Style TargetType="Button">
                    <Setter Property="Width" Value="100"/>
                    <Setter Property="Height" Value="35"/>
                    <Setter Property="Margin" Value="5"/>
                    <Setter Property="Background" Value="#4DA6FF"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Style.Resources>
                </Style>
            </StackPanel.Resources>

            <Button x:Name="btnTiepNhan" Content="Tiếp nhận sổ" Click="btnTiepNhan_Click"/>
            <Button x:Name="btnTaoMoi" Content="Tạo sổ mới" Click="btnTaoMoi_Click"/>
            <Button x:Name="btnTimKiem" Content="Tìm sổ" Click="btnTimKiem_Click"/>
            <Button x:Name="btnXoa" Content="Xóa sổ" Click="btnXoa_Click"/>
            <Button x:Name="btnCapNhat" Content="Cập nhật sổ" Click="btnCapNhat_Click"/>
            <Button x:Name="btnThoat" Content="Thoát" Click="btnThoat_Click" Background="#FF4D4D"/>
        </StackPanel>
    </Grid>
</Window>
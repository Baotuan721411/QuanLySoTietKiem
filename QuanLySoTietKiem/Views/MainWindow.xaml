<Window x:Class="QuanLySoTietKiem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:QuanLySoTietKiem.ViewModels"
        Title="Quản lý sổ tiết kiệm" Height="700" Width="900" 
        WindowStartupLocation="CenterScreen" Background="#FFFDE7">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Quản lý sổ tiết kiệm" FontSize="24" FontWeight="Bold" 
                   Foreground="#333" Margin="0,0,0,20"/>

        <!-- Form -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,15,10">
                <TextBlock Text="Mã sổ:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding MaSo}" IsEnabled="False" Height="32" 
                         VerticalContentAlignment="Center" Background="#F0F0F0"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,15,10">
                <TextBlock Text="Khách hàng:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding TenKH, UpdateSourceTrigger=PropertyChanged}" 
                         Height="32" VerticalContentAlignment="Center"/>
            </StackPanel>
            
            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,15,10">
                <TextBlock Text="Ngày sinh:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <DatePicker SelectedDate="{Binding NgaySinh}" Height="32"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,15,10">
                <TextBlock Text="Số tiền gửi:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding SoTienStr, UpdateSourceTrigger=PropertyChanged}" 
                         Height="32" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="0" Grid.Column="1" Margin="15,0,0,10">
                <TextBlock Text="Loại tiết kiệm:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding ListLoaiTK}" 
                          SelectedValuePath="MaLoaiTietKiem" 
                          DisplayMemberPath="TenLoaiTietKiem" 
                          SelectedValue="{Binding SelectedLoaiId}" 
                          Height="32" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Grid.Column="1" Margin="15,0,0,10">
                <TextBlock Text="CCCD:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding CCCD, UpdateSourceTrigger=PropertyChanged}" 
                         Height="32" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="1" Margin="15,0,0,10">
                <TextBlock Text="Ngày mở sổ:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <DatePicker SelectedDate="{Binding NgayMoSo}" Height="32"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Grid.Column="1" Margin="15,0,0,10">
                <TextBlock Text="Địa chỉ:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Text="{Binding DiaChi, UpdateSourceTrigger=PropertyChanged}" 
                         Height="32" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Action Buttons + Search -->
        <Grid Grid.Row="2" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Buttons -->
            <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                <WrapPanel.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Width" Value="110"/>
                        <Setter Property="Height" Value="35"/>
                        <Setter Property="Margin" Value="0,0,8,0"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Style.Resources>
                    </Style>
                </WrapPanel.Resources>

                <Button Content="Tiếp nhận sổ" Command="{Binding TiepNhanCommand}" Background="#4DA6FF"/>
                <Button Content="Tạo sổ mới" Command="{Binding TaoMoiCommand}" Background="#4DA6FF"/>
                <Button Content="Cập nhật sổ" Command="{Binding CapNhatSoCommand}" Background="#FFA726"/>
                <Button Content="Xóa sổ" Command="{Binding XoaSoCommand}" Background="#EF5350"/>
                <Button Content="Thoát" Command="{Binding ThoatCommand}" Background="#FF4D4D"/>
            </WrapPanel>

            <!-- Search -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBox Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" 
                         Width="200" Height="35" VerticalContentAlignment="Center" Margin="0,0,8,0"
                         ToolTip="Nhập mã sổ hoặc tên khách hàng"/>
                <Button Content="Tìm sổ" Command="{Binding TimSoCommand}" 
                        Width="80" Height="35" Background="#4DA6FF" Foreground="White" 
                        FontWeight="Bold" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <!-- DataGrid -->
        <DataGrid Grid.Row="3" ItemsSource="{Binding DanhSachSo}" 
                  SelectedItem="{Binding SelectedSo}"
                  AutoGenerateColumns="False" IsReadOnly="True" 
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionMode="Single" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" AlternatingRowBackground="#FFF8E1"
                  Margin="0,5,0,0" VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã sổ" Binding="{Binding MaSo}" Width="140"/>
                <DataGridTextColumn Header="Khách hàng" Binding="{Binding TenKH}" Width="140"/>
                <DataGridTextColumn Header="Loại TK" Binding="{Binding TenLoaiTietKiem}" Width="110"/>
                <DataGridTextColumn Header="Số tiền" Binding="{Binding SoTien, StringFormat={}{0:N0}}" Width="120"/>
                <DataGridTextColumn Header="CCCD" Binding="{Binding CCCD}" Width="120"/>
                <DataGridTextColumn Header="Ngày sinh" Binding="{Binding NgaySinh, StringFormat={}{0:dd/MM/yyyy}}" Width="95"/>
                <DataGridTextColumn Header="Ngày mở sổ" Binding="{Binding NgayMoSo, StringFormat={}{0:dd/MM/yyyy}}" Width="95"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <TextBlock Grid.Row="4" Margin="0,8,0,0" Foreground="#888" FontSize="11">
            <TextBlock.Text>
                <MultiBinding StringFormat="Tổng: {0} sổ tiết kiệm">
                    <Binding Path="DanhSachSo.Count"/>
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>
    </Grid>
</Window>
